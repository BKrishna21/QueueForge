// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model job {
  id        String    @id @default(uuid())
  type      String
  payload   Json
  status    String    @default("pending")
  progress  Int       @default(0)
  result    Json?
  errormessage String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  workername String?
  retrycount Int      @default(0)
  maxretries Int      @default(3)
  runat     DateTime  @default(now())
  priority  String    @default("medium")
  visibilitytimeout   DateTime?
  queueid   String 
  queue queue @relation(fields: [queueid], references: [id])
  deadletter  deadletterrecord?
  startedat  DateTime?
  completedat DateTime?
  timeoutat  DateTime?
  
}

model worker {
  id              String @id @default(uuid())
  name            String @unique
  status          String
  currentjobid    String? @unique
  lastheartbeat   DateTime
  startedAt       DateTime @default(now())
  jobsprocessed   Int      @default(0)
  successfuljobs  Int      @default(0)
  failedjobs      Int      @default(0)
  totalprocessingtime  Int @default(0)
  isleader        Boolean  @default(false)

}


model queue {

  id              String   @id @default(uuid())
  name            String   @unique
  status          String   @default("active")
  description     String?
  defaultpriority String   @default("medium")
  maxretries      Int      @default(3)
  pollinterval    Int      @default(10000)
  isratelimited   Boolean  @default(false)
  maxjobsperminute Int     @default(60)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  jobs            job[]
  lastresettime   DateTime @default(now())
  processedjobs   Int      @default(0)
  timeout         Int      @default(30000)

}

model deadletterrecord {

  id      String     @id @default(uuid())
  jobid   String     @unique
  job job @relation(fields: [jobid], references: [id])
  failedat DateTime  @default(now())
  failedbyworker  String?
  errormessage  String?

}
